# Your Supabase project URL  ->  Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co  # TODO: Replace with your Supabase project URL

# Your Supabase anon/public key  ->  Settings > API > anon public
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here  # TODO: Replace with your Supabase anon key

# Internal app ID (optional, safe to leave as-is for local dev)
VITE_APP_ID=your-app-id  # TODO: Replace with your app ID if needed
